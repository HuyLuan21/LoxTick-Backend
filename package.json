{
  "name": "tiktok-backend",
  "version": "1.0.0",
  "main": "src/app.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon src/app.js",
    "start": "node src/app.js",
    "migrate:dev": "cross-env NODE_ENV=development npx sequelize-cli db:migrate",
    "migrate:prod": "cross-env NODE_ENV=production npx sequelize-cli db:migrate",
    "migrate:undo:dev": "cross-env NODE_ENV=development npx sequelize-cli db:migrate:undo",
    "migrate:seed:dev": "cross-env NODE_ENV=development npx sequelize-cli db:seed:all",
    "seed:dev": "cross-env NODE_ENV=development npx sequelize-cli db:seed:all",
    "seed:prod": "cross-env NODE_ENV=production npx sequelize-cli db:seed:all",
    "seed:undo:dev": "cross-env NODE_ENV=development npx sequelize-cli db:seed:undo:all",
    "seed:undo:prod": "cross-env NODE_ENV=production npx sequelize-cli db:seed:undo:all"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "nodemailer": "^8.0.2",
    "redis": "^5.11.0",
    "sequelize": "^6.35.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.0",
    "sequelize-cli": "^6.6.5"
  }
}
